# ============================================================================
# FABRIC FINDER - ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!

# ============================================================================
# AI & SCRAPING APIs
# ============================================================================
ANTHROPIC_API_KEY=your_anthropic_key_here
FIRECRAWL_API_KEY=your_firecrawl_key_here
SERP_API_KEY=your_serpapi_key_here
BRAVE_API_KEY=your_brave_key_here

# ============================================================================
# DATABASE (Supabase)
# ============================================================================
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ============================================================================
# MONETIZATION
# ============================================================================
AMAZON_ASSOCIATE_TAG=your_amazon_associate_tag_here

# ============================================================================
# ADMIN ACCESS
# ============================================================================
# Generate a strong random string for production (use: openssl rand -hex 32)
ADMIN_SECRET_KEY=your_secure_random_string_here

# ============================================================================
# ENVIRONMENT
# ============================================================================
# Set to 'production' on Render
NODE_ENV=development

# ============================================================================
# SERVER
# ============================================================================
PORT=3000
